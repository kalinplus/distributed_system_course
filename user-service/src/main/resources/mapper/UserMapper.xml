<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.course.ecommerce.mapper.UserMapper">

    <!-- 按用户名查询用户 -->
    <select id="findByUsername" resultType="com.course.ecommerce.entity.User">
        SELECT id,
               username,
               password_hash,
               phone,
               email,
               status,
               created_at,
               updated_at
        FROM t_user
        WHERE username = #{username}
    </select>

</mapper>
